# Backend environment variables
NODE_ENV=development
PORT=4000

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/gpt_rewards

# JWT/Auth
JWT_SECRET=replace_with_strong_secret
JWT_EXPIRES_IN=7d

# Redis
REDIS_URL=redis://localhost:6379

# Payout providers (placeholders)
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=

# HMAC secrets per provider (placeholders)
POSTBACK_SECRET_OFFERWALL_DEFAULT=replace_me